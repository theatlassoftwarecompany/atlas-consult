{
  "family": "atlas-consult-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::879986119914:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "atlas-consult",
      "image": "879986119914.dkr.ecr.eu-west-2.amazonaws.com/atlas-consult:61e485be41850956105413d2d8c966791e78d9ec",
      "essential": true,
      "environment": [],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/DB_HOST"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/DB_USER"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/DB_PASSWORD"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/DB_NAME"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/RESEND_API_KEY"
        },
        {
          "name": "FROM_EMAIL",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/FROM_EMAIL"
        },
        {
          "name": "NOTIFY_EMAIL",
          "valueFrom": "arn:aws:ssm:eu-west-2:879986119914:parameter/arbitor/NOTIFY_EMAIL"
        }
      ],
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/atlas-consult",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://$(hostname -i | tr -d ' '):3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ]
}
